{
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "cmake.configureOnOpen": false,
    "cmake.testArgs": [
        "--output-on-failure"
    ],
    "files.watcherExclude": {
        "**/build/**": true,
        "**/out/build/**": true,
        "**/.git/objects/**": true
    },
    "search.exclude": {
        "**/build/**": true,
        "**/out/build/**": true
    },
    "commentTranslate.source": "TranSmart",
    "commentTranslate.targetLanguage": "zh-CN"
}